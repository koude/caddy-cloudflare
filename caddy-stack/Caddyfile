{
    email {$ACME_EMAIL}
    auto_https disable_redirects
}

(tls_cf) {
    tls {
        dns cloudflare {env.CF_API_TOKEN}
    }
}

(insecure_https_upstream) {
    transport http {
        tls_insecure_skip_verify
    }
}

https://koude.win:20443, https://*.koude.win:20443 {
    bind 192.168.50.3
    import tls_cf

    import routes/*.caddy

    handle {
        respond "not found" 404
    }
}
